ASPNETCORE_ENVIRONMENT=Production
ALLOWED_HOSTS=*
WEB_PORT=8080

DB_HOST=db
DB_PORT=1433
DB_PUBLISH_PORT=1434
DB_NAME=myDB
DB_USER=sa
DB_SA_PASSWORD=ReplaceWithAStrongSqlPassword
DB_ENCRYPT=False
MSSQL_PID=Developer

JWT_ISSUER=WedProject
JWT_AUDIENCE=WedProjectClient
JWT_USE_ASYMMETRIC=false
JWT_SECRET_KEY=ReplaceWithAVeryLongRandomSecretAtLeast32Chars
JWT_AUTO_GENERATE_DEVELOPMENT_KEY=false
JWT_ACCESS_TOKEN_MINUTES=60
JWT_REMEMBER_ME_DAYS=7

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_ENABLE_SSL=true
SMTP_USERNAME=replace-with-your-smtp-username
SMTP_PASSWORD=replace-with-your-smtp-password
SMTP_FROM_EMAIL=no-reply@synaplearn.local
SMTP_FROM_NAME=SynapLearn

GOOGLE_AUTH_CLIENT_ID=replace-with-your-google-client-id.apps.googleusercontent.com
GROQ_API_KEY=replace-with-your-groq-api-key
GEMINI_API_KEY=replace-with-your-gemini-api-key

ADMIN_ACCOUNT_USERNAME=
ADMIN_ACCOUNT_EMAIL=
ADMIN_ACCOUNT_PASSWORD=
ADMIN_ACCOUNT_FULL_NAME=
